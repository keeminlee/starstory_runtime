# Track C web auth (Run 1)
# Discord OAuth app credentials.
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# Auth.js secret (generate a long random string).
AUTH_SECRET=""

# Local development URL for Auth.js callbacks.
NEXTAUTH_URL="http://localhost:3000"

# Local dev-only explicit bypass (header/query guild override).
DEV_WEB_BYPASS="0"

# Expose temporary ARG debug controls outside development when needed.
NEXT_PUBLIC_STARSTORY_DEBUG_PANEL="false"

# Run 2B: Discord guild refresh TTL in milliseconds (default 300000 / 5m).
MEEPO_WEB_DISCORD_GUILDS_TTL_MS="300000"
