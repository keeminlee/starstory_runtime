# Meepo bot runtime environment
# Copy values from .env.example and set production secrets.

DISCORD_TOKEN=
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

MEEPO_MODE=ambient
LOG_LEVEL=info
LOG_FORMAT=json

DATA_DB_PATH=/home/meepo/meepo-bot/data/control/control.sqlite
MEEPO_AUTO_SLEEP_MS=600000

GUILD_ID=
DISCORD_CLIENT_ID=
DM_ROLE_ID=
DM_USER_IDS=
DEV_USER_IDS=
ANNOUNCEMENT_CHANNEL_ID=

OVERLAY_PORT=7777
OVERLAY_VOICE_CHANNEL_ID=
MEEPO_HOME_VOICE_CHANNEL_ID=
VOICE_AUTO_RECONNECT=true

TTS_PROVIDER=noop
STT_PROVIDER=whisper
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=200

# Optional provider-specific model defaults
STT_OPENAI_MODEL=gpt-4o-mini-transcribe
STT_DEEPGRAM_MODEL=nova-3
ANTHROPIC_MODEL=claude-3-5-haiku-latest
GOOGLE_MODEL=gemini-2.0-flash

# Current shipped defaults remain OpenAI-backed whisper for STT and OpenAI for LLM.
# Guild settings can now override STT to whisper|deepgram and LLM to openai|anthropic|google.
LLM_ENABLED=true