# Copy to /etc/meepo/meepo-bot.env and fill values.
NODE_ENV=production
DATA_ROOT=/home/meepo/meepo-data
DISCORD_TOKEN=
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Optional global DM role fallback (prefer guild-config dm_role_id when set).
DM_ROLE_ID=

# Optional global operator allowlist for DM/admin command surfaces.
DM_USER_IDS=

# Optional dev-only allowlist for /lab command surface.
DEV_USER_IDS=

# Optional bot behavior toggles
TTS_ENABLED=0
TTS_PROVIDER=noop
STT_PROVIDER=whisper
LLM_PROVIDER=openai

# Optional provider-specific model defaults
OPENAI_MODEL=gpt-4o-mini
STT_DEEPGRAM_MODEL=nova-3
ANTHROPIC_MODEL=claude-3-5-haiku-latest
GOOGLE_MODEL=gemini-2.0-flash
