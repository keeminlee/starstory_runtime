# Copy to /etc/meepo/meepo-bot.env and fill values.
NODE_ENV=production
DATA_ROOT=/home/meepo/meepo-data
DISCORD_TOKEN=
OPENAI_API_KEY=

# Comma-separated Discord user IDs allowed to access /lab commands.
DEV_USER_IDS=123456789012345678,987654321098765432

# Optional bot behavior toggles
TTS_ENABLED=0
TTS_PROVIDER=noop
