# Copy to /etc/meepo/meepo-web.env and fill values.
NODE_ENV=production
PORT=3000
NEXTAUTH_URL=https://starstory.online
AUTH_URL=https://starstory.online
AUTH_TRUST_HOST=true
AUTH_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
STARSTORY_DEBUG_PANEL=true

# Canonical-origin policy (required):
# - starstory.online is the only production auth origin.
# - meepo.online must be redirect-only at nginx.
# - Do not initiate OAuth from non-canonical hosts.

# Shared runtime data root
DATA_ROOT=/home/meepo/meepo-data

# LLM provider keys for web-side recap generation.
# In local dev, these can be inherited from the shared repo-root env.
# In production, the web service runs in its own systemd unit with a
# separate EnvironmentFile, so required keys must be duplicated here.
# Long-term target: migrate to AWS Secrets Manager.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
