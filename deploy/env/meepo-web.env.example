# Copy to /etc/meepo/meepo-web.env and fill values.
NODE_ENV=production
PORT=3000
NEXTAUTH_URL=https://meepo.online
AUTH_URL=https://meepo.online
AUTH_TRUST_HOST=true
AUTH_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
NEXT_PUBLIC_STARSTORY_DEBUG_PANEL=true

# Canonical-origin policy (required):
# - meepo.online is the only production auth origin.
# - starstory.online must be redirect-only at nginx.
# - Do not initiate OAuth from non-canonical hosts.

# Shared runtime data root
DATA_ROOT=/home/meepo/meepo-data
