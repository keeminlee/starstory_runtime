# Meepo web runtime environment
PORT=3000
NODE_ENV=production

# Discord OAuth credentials
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Auth.js secret and canonical production URL
AUTH_SECRET=
NEXTAUTH_URL=https://meepo.online
AUTH_URL=https://meepo.online
AUTH_TRUST_HOST=true
NEXT_PUBLIC_STARSTORY_DEBUG_PANEL=true

# Optional development bypass (keep disabled in prod)
DEV_WEB_BYPASS=0

# Canonical-origin policy:
# - meepo.online is the only production auth origin
# - starstory.online must redirect to meepo.online at the proxy layer

# Optional guild cache TTL override
MEEPO_WEB_DISCORD_GUILDS_TTL_MS=300000